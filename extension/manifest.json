{
  "manifest_version": 3,
  "name": "Talental — LinkedIn → ATS",
  "description": "Side panel con el perfil del candidato dentro de tu ATS, sincronizado con la pestaña de LinkedIn que tengas abierta.",
  "version": "0.5.1",
  "action": {
    "default_title": "Talental — abrir side panel"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "permissions": ["storage", "activeTab", "tabs", "sidePanel"],
  "host_permissions": [
    "https://app.talental.mx/*",
    "https://*.vercel.app/*",
    "http://localhost:3000/*"
  ]
}
