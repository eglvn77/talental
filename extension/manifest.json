{
  "manifest_version": 3,
  "name": "Talental — LinkedIn → ATS",
  "description": "Side panel showing the candidate's profile inside your ATS, synced with the LinkedIn tab you have open.",
  "version": "0.6.0",
  "action": {
    "default_title": "Talental — open side panel"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "permissions": ["storage", "activeTab", "tabs", "sidePanel"],
  "host_permissions": [
    "https://app.talental.mx/*",
    "https://*.vercel.app/*",
    "http://localhost:3000/*"
  ]
}
