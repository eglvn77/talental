{
  "manifest_version": 3,
  "name": "Talental — LinkedIn → ATS",
  "description": "Detecta si el perfil ya está en tu ATS, o agrégalo con un click (enriquece automáticamente vía Coresignal + Unipile).",
  "version": "0.4.0",
  "action": {
    "default_title": "Talental",
    "default_popup": "src/popup/index.html"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://app.talental.mx/*",
    "https://*.vercel.app/*",
    "http://localhost:3000/*"
  ]
}
